---
import { cn } from '~/lib/utils'
import { PHOTOS_CONFIG, PhotosList } from '~/config'
import Layout from '~/layouts/Layout.astro'
import PhotoTimeline from '~/components/photos/PhotoTimeline.astro'

const { title, description, introduce } = PHOTOS_CONFIG
---

<Layout {title} {description}>
  <div class="relative z-[1] py-8 pb-10">
    <div class="px-6 sm:px-8">
      <h1 class="tracking-tight text-4xl bg-gradient-to-r from-primary to-primary/70 bg-clip-text text-transparent pb-1.5">{title}</h1>
      <div class="pro text-muted-foreground text-balance">
        <p class="mt-2">{introduce}</p>
      </div>
    </div>

    <!-- 摄影时间轴 -->
    <div class="mt-12 px-6 sm:px-8">
      {
        PhotosList.length > 0 ? (
          <PhotoTimeline photoData={PhotosList} />
        ) : (
          <div class="text-muted-foreground mb-4">
            <p class="text-sm">还没有照片，等我学成归来，OvO</p>
          </div>
        )
      }
    </div>
  </div>
</Layout>
